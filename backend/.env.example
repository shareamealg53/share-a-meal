# ShareAMeal v2.0.0 - Environment Configuration

## Node Environment
# development = uses nodemon, verbose logging
# production = optimized for Render/production deployment
NODE_ENV=development
PORT=3000

## Database Configuration
# LOCAL DEVELOPMENT: Use localhost with local MySQL
# PRODUCTION (Render + Aiven): Use Aiven MySQL connection details
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=sharemeal

# For Aiven MySQL (Production):
# DB_HOST=your-service-name.aivencloud.com
# DB_PORT=3306
# DB_USER=avnadmin
# DB_PASSWORD=<your-aiven-password>
# DB_NAME=defaultdb

## Authentication Secrets
# !! IMPORTANT: Generate secure random strings (min 32 characters) for production !!
JWT_SECRET=your-super-secret-jwt-key-here-minimum-32-characters
JWT_EXPIRES_IN=24h

## Email Configuration (for email verification)
# In development: Uses Ethereal (fake SMTP) automatically - no config needed
# In production: Use a real email service (Gmail, SendGrid, Mailgun, etc.)

# Example with Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password (not your regular password!)
# SMTP_FROM=noreply@yourdomain.com

# Example with SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
# SMTP_FROM=noreply@yourdomain.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@shareameal.com

# URLs for email links
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

## Optional: Service Token (For AI team)
SERVICE_TOKEN=your-service-token-for-ai-here

## DEPLOYMENT INSTRUCTIONS:

### Local Development
# 1. Copy this file to .env (remove .example)
# 2. Set NODE_ENV=development
# 3. Use localhost for DB_HOST with local MySQL
# 4. Run: npm run dev

### Docker Local Testing
# 1. Run: docker-compose up
# 2. App runs on http://localhost:3000
# 3. MySQL available at localhost:3306
# 4. All environment variables in docker-compose.yml

### Production on Render + Aiven (100% FREE)
# 1. Create Aiven MySQL database (free 1GB):
#    - Sign up at https://aiven.io
#    - Create MySQL service (Startup-4 free tier)
#    - Get connection details (host, user, password)
# 2. In Render dashboard, set these environment variables:
#    - NODE_ENV: production
#    - DB_HOST: your-service.aivencloud.com (from Aiven)
#    - DB_PORT: 3306
#    - DB_USER: avnadmin (from Aiven)
#    - DB_PASSWORD: <your-aiven-password>
#    - DB_NAME: defaultdb (or your Aiven database name)
#    - JWT_SECRET: generate secure random string (min 32 chars)
#    - SMTP_HOST: your-smtp-host (e.g., smtp.sendgrid.net)
#    - SMTP_PORT: 587
#    - SMTP_USER: your-smtp-username
#    - SMTP_PASS: your-smtp-password
#    - SMTP_FROM: noreply@yourdomain.com
#    - API_URL: https://your-app.onrender.com
#    - FRONTEND_URL: https://your-frontend.vercel.app
#    - PORT: (Render sets automatically, leave empty)
# 3. Push code to GitHub
# 4. Connect GitHub repo to Render
# 5. Render auto-detects from render.yaml
# 6. Deploy and migrations run automatically

### Important Notes
# - Never commit .env to version control
# - Keep all secrets secure (JWT_SECRET, DB_PASSWORD)
# - Use different secrets for each environment
# - Render provides built-in environment variable management
